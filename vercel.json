{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }, 
    {
      "src": "src/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/src/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/sync?action=live",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/sync?action=matches",
      "schedule": "0 */6 * * *"
    }
  ]
}
